# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development

# Admin User
ADMIN_EMAIL=admin@wedspace.local
ADMIN_PASSWORD=admin123

# Database Configuration
# Development: PostgreSQL local
# Production: PostgreSQL managed (Railway/Render)
DATABASE_URL=postgresql://user:password@localhost:5432/wedspace

# CORS Configuration
# Development: http://localhost:5173
# Production: https://your-vercel-domain.vercel.app,https://your-custom-domain.com
# Multiple domains: comma-separated, no spaces
CORS_ORIGINS=http://localhost:5173
